# === LLM HOST (obrigatório para rodar missões no demo) ===
# Gemini direto (Google AI Studio) — free tier estável, usado no host.
# Crie em: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# === LLM PREMIUM / BYOK (opcional) ===
# OpenRouter — usado SÓ quando o visitante fornece a própria chave para
# destravar modelos premium (ex.: Claude). Não é necessário para o host.
# OPENROUTER_API_KEY=sk-or-...

# === BUSCA (ARIA — Fatia 2) ===
# TAVILY_API_KEY=...
# BRAVE_API_KEY=...

# === GUARDS (Fatia 4 — proteção de custo, ADR-0002) ===
# Teto de orçamento diário GLOBAL do host (USD). Ao ultrapassar, o kill-switch
# desliga as missões no host (premium/BYOK continuam, pois a carteira é do
# visitante). Ausente → sem teto (bom p/ rodar local/Self-Hoster).
# DAILY_BUDGET_USD=5
# Missões por IP por janela de 60s. Ausente → default 10.
# RATE_LIMIT_PER_IP=10

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=STARDECK

# === FASE 2 (diferido — Supabase/Comandante) ===
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
